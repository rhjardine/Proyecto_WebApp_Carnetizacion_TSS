APP_ENV=development
APP_DEBUG=true
APP_NAME=SCI-TSS
APP_VERSION=2.6.0

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=carnetizacion_tss
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

SESSION_LIFETIME=3600
SESSION_SECURE=false
SESSION_HTTPONLY=true
SESSION_SAMESITE=Strict

ENFORCE_HTTPS=false
ENFORCE_CSRF=true
CSRF_TOKEN_EXPIRY=7200

PASS_ROTATION_DAYS=90
PASSWORD_MIN_LENGTH=12
PASSWORD_EXPIRY_DAYS=90

LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15
API_RATE_LIMIT=100

MAX_PHOTO_SIZE=5242880

APP_URL=http://localhost
API_BASE_URL=http://localhost/api

LOG_LEVEL=debug
LOG_PATH=./logs
