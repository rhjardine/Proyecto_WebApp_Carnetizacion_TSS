# ============================================================
# SCI-TSS .htaccess — Configuración Apache para php-app/
# ============================================================
# CORREGIDO v2.2: Eliminado <DirectoryMatch> (no permitido en .htaccess)

# 1. Enable Rewrite Engine
RewriteEngine On

# 2. Prevent directory listing (Security)
Options -Indexes

# 3. Protect sensitive files (dotfiles, SQL, env, config)
<FilesMatch "^\.">
    Require all denied
</FilesMatch>

<FilesMatch "\.(sql|env|ini|log|bak|rar|zip)$">
    Require all denied
</FilesMatch>

# 4. Protect sensitive directories via Rewrite (since DirectoryMatch not allowed here)
# Block direct access to db/, config/, includes/ directories
RewriteRule ^db/ - [F,L]
RewriteRule ^includes/ - [F,L]
RewriteRule ^api/config/ - [F,L]

# 5. Handle CORS headers
<IfModule mod_headers.c>
    Header set Access-Control-Allow-Origin "*"
    Header set Access-Control-Allow-Methods "GET, POST, PUT, PATCH, DELETE, OPTIONS"
    Header set Access-Control-Allow-Headers "Origin, X-Requested-With, Content-Type, Accept, Authorization, X-CSRF-Token"
    Header set Access-Control-Allow-Credentials "true"
</IfModule>

# 6. PHP settings for uploads
<IfModule mod_php.c>
    php_value upload_max_filesize 12M
    php_value post_max_size 14M
    php_value max_execution_time 30
</IfModule>
